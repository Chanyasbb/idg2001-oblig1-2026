DATA_CSV_PATH=data/olympic.csv
DEFAULT_TOKENS=100
TOKENS_PER_MONEY=10
CACHE_URL=http://cache:8001
LOGGER_URL=http://logger:8002
RATE_LIMITER_URL=http://rate_limiter:8003
TOKEN_SHOP_URL=http://token_shop:8004
